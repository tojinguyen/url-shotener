# Application mode: shortener | redirector | all
APP_MODE=all

# HTTP port the server listens on inside the container
PORT=8080

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB=urlshortener

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Expiration applied to every newly created short URL
DEFAULT_TTL_DAYS=30

# In-memory Bloom filter sizing (shortener/all mode only)
BLOOM_CAPACITY=10000000
BLOOM_FP_RATE=0.001
